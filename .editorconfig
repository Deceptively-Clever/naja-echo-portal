root = true

# All files
[*]
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

# C# files
[*.cs]
indent_size = 4
charset = utf-8

# Code style rules
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_parameter_list_parentheses = false

# Naming conventions
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.severity = suggestion
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.symbols = interface
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.style = begins_with_i
dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.required_suffix =
dotnet_naming_style.begins_with_i.word_separator =
dotnet_naming_style.begins_with_i.capitalization = pascal_case

# StyleCop rules - suppress overly strict or opinionated rules
dotnet_diagnostic.SA0001.severity = silent      # XML comment analysis disabled
dotnet_diagnostic.SA1009.severity = none        # Parenthesis spacing
dotnet_diagnostic.SA1010.severity = none        # Opening square bracket spacing
dotnet_diagnostic.SA1011.severity = none        # Closing square bracket spacing
dotnet_diagnostic.SA1025.severity = none        # Multiple whitespace characters
dotnet_diagnostic.SA1101.severity = none        # Use base class name
dotnet_diagnostic.SA1116.severity = none        # Parameter alignment (line breaks)
dotnet_diagnostic.SA1117.severity = none        # Parameter alignment (same/separate lines)
dotnet_diagnostic.SA1127.severity = none        # Generic constraint formatting
dotnet_diagnostic.SA1200.severity = none        # Using directives outside namespace
dotnet_diagnostic.SA1202.severity = none        # Element ordering by access level
dotnet_diagnostic.SA1210.severity = none        # Using directives ordering
dotnet_diagnostic.SA1309.severity = none        # Field names should not begin with underscore
dotnet_diagnostic.SA1313.severity = none        # Record parameter names (PascalCase fine for DTOs)
dotnet_diagnostic.SA1413.severity = none        # Multi-line initializer trailing comma
dotnet_diagnostic.SA1502.severity = none        # Element on same line
dotnet_diagnostic.SA1512.severity = none        # Comment followed by blank line
dotnet_diagnostic.SA1513.severity = none        # Brace followed by blank line
dotnet_diagnostic.SA1515.severity = none        # Comment preceded by blank line
dotnet_diagnostic.SA1516.severity = none        # Elements separated by blank line
dotnet_diagnostic.SA1519.severity = none        # Braces for single statement block
dotnet_diagnostic.SA1600.severity = none        # Missing documentation
dotnet_diagnostic.SA1601.severity = none        # Partial elements missing documentation
dotnet_diagnostic.SA1633.severity = none        # File header required

# StyleCop rules - enforce
dotnet_diagnostic.SA1503.severity = warning     # Braces required (prevents bugs)
dotnet_diagnostic.SA1000.severity = warning     # Keyword spacing (readability)
dotnet_diagnostic.SA1122.severity = warning     # Use string.Empty (best practice)

# Code quality
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_operators = false:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_accessors = true:silent
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_inline_out_variable_declaration = true:suggestion
csharp_style_throw_expression = true:suggestion
# Null-checking preference
csharp_style_conditional_delegate_call = true:suggestion
# Analyzers
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1711.severity = none
dotnet_diagnostic.CA1716.severity = none
dotnet_diagnostic.CA1720.severity = none
dotnet_diagnostic.CA1724.severity = none
dotnet_diagnostic.CA1806.severity = none
dotnet_diagnostic.CA1812.severity = none
dotnet_diagnostic.CA1820.severity = none
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.CA1823.severity = none
dotnet_diagnostic.CA2201.severity = none

# NuGet warnings
dotnet_diagnostic.NU1603.severity = none        # Package version mismatch
