#!/bin/bash
set -e

echo "Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FAILED=0

# Check if files changed in frontend
if git diff --cached --name-only --diff-filter=ACM | grep -q "^frontend/"; then
  echo -e "${YELLOW}Running frontend linting...${NC}"
  if (cd frontend && npm run lint > /dev/null 2>&1); then
    echo -e "${GREEN}✓ Frontend lint passed${NC}"
  else
    echo -e "${RED}✗ Frontend lint failed${NC}"
    echo "Fix linting errors before committing:"
    (cd frontend && npm run lint)
    FAILED=1
  fi
fi

# Check if files changed in backend
if git diff --cached --name-only --diff-filter=ACM | grep -q "^backend/"; then
  echo -e "${YELLOW}Running backend code analysis...${NC}"
  if (cd backend && dotnet build NajaEcho.slnx -c Release /p:EnforceCodeStyleInBuild=true /p:EnableNETAnalyzers=true > /dev/null 2>&1); then
    echo -e "${GREEN}✓ Backend analysis passed${NC}"
  else
    echo -e "${RED}✗ Backend analysis failed${NC}"
    echo "Fix code analysis issues before committing:"
    (cd backend && dotnet build NajaEcho.slnx -c Release /p:EnforceCodeStyleInBuild=true /p:EnableNETAnalyzers=true)
    FAILED=1
  fi
fi

if [ $FAILED -ne 0 ]; then
  echo -e "${RED}Pre-commit checks failed${NC}"
  exit 1
fi

echo -e "${GREEN}✓ All pre-commit checks passed${NC}"
exit 0
